# ENV CONTRACT
# - Backend secret vars: NEVER exposed to browser bundles.
# - Frontend-safe vars: must be prefixed with VITE_.

# GEMINI_API_KEY (Backend Secret, Required in production)
# Used only by server-side validation route.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL (Backend/Runtime, Optional)
# Public app URL used for callbacks/self-referential links when needed.
APP_URL="MY_APP_URL"

# SERVER_PORT (Backend Runtime, Optional)
# Local API port for backend validation endpoint.
SERVER_PORT="8787"

# VALIDATION_RATE_LIMIT_MAX (Backend Runtime, Optional)
# Max /api/validate requests per 15-minute window per IP.
VALIDATION_RATE_LIMIT_MAX="60"

# LIVE_SEARCH_RATE_LIMIT_MAX (Backend Runtime, Optional)
# Max /api/live-search requests per 15-minute window per IP.
LIVE_SEARCH_RATE_LIMIT_MAX="30"

# CORS_ALLOWLIST (Backend Runtime, Optional)
# Comma-separated allowed origins for API calls.
CORS_ALLOWLIST="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173"

# VITE_API_BASE_URL (Frontend Safe, Required)
# Browser-visible API base URL for frontend requests.
VITE_API_BASE_URL="http://localhost:8787"
